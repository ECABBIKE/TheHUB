# GravitySeries — Clean URL routing
# /gravityseries/om-oss → /gravityseries/sida.php?slug=om-oss
# /gravityseries/serie/my-slug → /gravityseries/serie.php?slug=my-slug

RewriteEngine On
RewriteBase /gravityseries/

# Skip actual files (CSS, JS, images)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Skip directories
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serie detail page: /gravityseries/serie/{brand-slug}
RewriteRule ^serie/([a-z0-9-]+)/?$ serie.php?slug=$1 [QSA,L]

# CMS pages: /gravityseries/{slug}
RewriteRule ^([a-z0-9-]+)/?$ sida.php?slug=$1 [QSA,L]
